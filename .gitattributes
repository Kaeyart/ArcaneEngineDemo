* text=auto

# Text formats
*.cs text eol=lf
*.json text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.cginc text eol=lf
*.uxml text eol=lf
*.uss text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
