            for (int index = 0; index < qualityNames.Length; index++)
            {
                if (GUI.Button(new Rect(310f + (index % 5) * 185f, y + (index / 5) * 48f, 170f, 40f), qualityNames[index],
                    ArpgSettings31.QualityLevel == index ? _buttonSelected : _button))
